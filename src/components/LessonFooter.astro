---
interface LessonLink {
	href: string;
	title: string;
	description?: string;
}

interface Props {
	prevLesson: { href: string; title: string } | null;
	nextLesson: LessonLink | null;
}

const { prevLesson, nextLesson } = Astro.props;
---

<div class="lesson-footer">
	<div class="complete-row" aria-label="Lesson complete">
		<span class="complete-pip" aria-hidden="true">✦</span>
		<span class="complete-label">Lesson complete</span>
		<span class="complete-pip" aria-hidden="true">✦</span>
	</div>

	{
		nextLesson ? (
			<div class="next-block">
				<p class="next-eyebrow">Next</p>
				<p class="next-title">{nextLesson.title}</p>
				{nextLesson.description && <p class="next-desc">{nextLesson.description}</p>}
				<a href={nextLesson.href} class="btn-continue">
					Continue to {nextLesson.title} →
				</a>
			</div>
		) : (
			<div class="next-block">
				<p class="next-eyebrow">Module complete</p>
				<p class="next-title">You've finished this module.</p>
				<a href="/learn" class="btn-continue">
					Explore what's next →
				</a>
			</div>
		)
	}

	{
		prevLesson && (
			<p class="prev-row">
				<a href={prevLesson.href} class="prev-link">
					← {prevLesson.title}
				</a>
			</p>
		)
	}

	<aside class="email-card" aria-label="Free starter guide">
		<div class="email-inner">
			<p class="email-eyebrow" aria-hidden="true">✦</p>
			<h2 class="email-title">Get the Palmistry Starter Guide</h2>
			<p class="email-body">
				A printable quick-reference guide to the major lines, mounts, and hand shapes.
			</p>
			<div class="includes" aria-label="Guide contents">
				<p class="includes-label">Includes</p>
				<ul class="includes-list">
					<li>Major lines quick-reference map</li>
					<li>Mount meanings overview</li>
					<li>Hand shape guide</li>
					<li>Printable study sheet</li>
				</ul>
			</div>
			<a href="/guide" class="btn-guide">Get the Free Guide</a>
		</div>
	</aside>
</div>

<style>
	.lesson-footer {
		width: 720px;
		max-width: calc(100% - 2em);
		margin: 0 auto;
		padding: 2.5em 1em 4em;
		border-top: 1px solid rgba(201, 169, 110, 0.15);
	}

	/* ── Lesson complete marker ── */
	.complete-row {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.75em;
		margin-bottom: 2.25em;
		color: var(--accent);
	}
	.complete-pip {
		font-size: 0.6em;
		opacity: 0.6;
	}
	.complete-label {
		font-family: var(--font-cinzel), serif;
		font-size: 0.68em;
		letter-spacing: 0.2em;
		text-transform: uppercase;
	}

	/* ── Next lesson block ── */
	.next-block {
		text-align: center;
		margin-bottom: 1.75em;
	}
	.next-eyebrow {
		font-family: var(--font-cinzel), serif;
		font-size: 0.64em;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		color: var(--color-text-muted);
		margin: 0 0 0.45em;
	}
	.next-title {
		font-family: var(--font-cinzel), serif;
		font-size: clamp(1em, 4vw, 1.2em);
		color: var(--color-heading);
		margin: 0 0 0.5em;
		line-height: 1.3;
	}
	.next-desc {
		font-size: 0.84em;
		color: var(--color-text-muted);
		max-width: 460px;
		margin: 0 auto 1.35em;
		line-height: 1.7;
	}

	.btn-continue {
		display: inline-block;
		padding: 0.7em 1.9em;
		background: var(--accent);
		color: var(--color-bg);
		font-family: var(--font-cinzel), serif;
		font-size: 0.7em;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		text-decoration: none;
		border-radius: 4px;
		transition: background 0.15s ease;
	}
	.btn-continue:hover {
		background: var(--accent-light);
		color: var(--color-bg);
	}

	/* ── Previous link ── */
	.prev-row {
		text-align: center;
		margin-top: 1.1em;
		margin-bottom: 0;
	}
	.prev-link {
		font-size: 0.78em;
		color: var(--color-text-muted);
		text-decoration: none;
	}
	.prev-link:hover {
		color: var(--accent);
	}

	/* ── Email capture card ── */
	.email-card {
		margin-top: 3.5em;
		border: 1px solid rgba(201, 169, 110, 0.18);
		border-radius: 10px;
		background: rgba(255, 255, 255, 0.02);
	}
	.email-inner {
		padding: 2em 2em 2.25em;
		text-align: center;
	}
	.email-eyebrow {
		font-size: 0.65em;
		color: var(--accent);
		opacity: 0.55;
		margin: 0 0 0.75em;
		letter-spacing: 0.3em;
	}
	.email-title {
		font-family: var(--font-cinzel), serif;
		font-size: clamp(0.95em, 3.5vw, 1.25em);
		color: var(--color-heading);
		margin: 0 0 0.55em;
		letter-spacing: 0.04em;
		line-height: 1.3;
	}
	.email-body {
		font-size: 0.83em;
		color: var(--color-text-muted);
		max-width: 400px;
		margin: 0 auto 1em;
		line-height: 1.75;
	}

	/* ── Includes list ── */
	.includes {
		margin: 0 auto 1.6em;
		max-width: 260px;
		text-align: left;
	}
	.includes-label {
		font-family: var(--font-cinzel), serif;
		font-size: 0.57em;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--color-text-muted);
		opacity: 0.5;
		margin: 0 0 0.6em;
	}
	.includes-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.28em;
	}
	.includes-list li {
		font-size: 0.76em;
		color: var(--color-text-muted);
		opacity: 0.72;
		padding-left: 0.9em;
		position: relative;
		line-height: 1.5;
	}
	.includes-list li::before {
		content: '·';
		position: absolute;
		left: 0;
		color: var(--accent);
		opacity: 0.4;
	}

	.btn-guide {
		display: inline-block;
		padding: 0.65em 1.65em;
		border: 1px solid rgba(201, 169, 110, 0.4);
		color: var(--accent);
		font-family: var(--font-cinzel), serif;
		font-size: 0.68em;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		text-decoration: none;
		border-radius: 4px;
		transition:
			border-color 0.25s ease,
			background 0.25s ease,
			color 0.25s ease,
			box-shadow 0.25s ease;
	}
	.btn-guide:hover {
		border-color: rgba(201, 169, 110, 0.65);
		background: rgba(201, 169, 110, 0.07);
		color: var(--accent-light);
		box-shadow: 0 0 18px rgba(201, 169, 110, 0.1);
	}

	@media (max-width: 480px) {
		.email-inner {
			padding: 1.5em 1.25em 1.75em;
		}
		.btn-continue,
		.btn-guide {
			width: 100%;
			text-align: center;
			box-sizing: border-box;
		}
	}
</style>
