---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<HeaderLink href="/glossary">Glossary</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1.5em;
		background: var(--color-header-bg);
		border-bottom: 1px solid rgba(201, 169, 110, 0.12);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
		color: var(--color-nav-text);
		font-family: var(--font-cinzel), serif;
		letter-spacing: 0.08em;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.5em 0;
	}
	nav a {
		padding: 0.9em 0.5em;
		color: var(--color-nav-text);
		border-bottom: 2px solid transparent;
		text-decoration: none;
		font-size: 0.82em;
		letter-spacing: 0.07em;
		font-family: var(--font-cinzel), serif;
		transition: color 0.2s ease;
	}
	nav a.active {
		border-bottom-color: var(--color-nav-hover);
		color: var(--color-nav-hover);
	}
	nav a:hover {
		color: var(--color-nav-hover);
	}

	/* Tablet: tighten horizontal padding */
	@media (max-width: 720px) {
		header {
			padding: 0 1em;
		}
	}

	/* Phone: stack site name above nav links */
	@media (max-width: 600px) {
		header {
			padding: 0;
		}
		nav {
			flex-direction: column;
			align-items: center;
			gap: 0;
			padding: 0.8em 1em 0;
		}
		h2 {
			font-size: 0.95em;
		}
		/* Title link keeps its own tight padding — it's not a tap target */
		h2 a {
			padding: 0 0 0.6em;
			display: block;
		}
		.internal-links {
			display: flex;
			flex-wrap: wrap;
			justify-content: center;
			width: 100%;
			border-top: 1px solid rgba(201, 169, 110, 0.08);
		}
		/* Override nav a padding for the internal links only at mobile.
		   1em top + 1em bottom + ~15px font ≈ 45px tap target. */
		.internal-links a {
			padding: 1em 0.65em;
			font-size: 0.78em;
			letter-spacing: 0.05em;
		}
	}
</style>
