---
interface Props {
	src: string;
	alt: string;
	caption?: string;
}

const { src, alt, caption } = Astro.props;
---

<figure>
	<img src={src} alt={alt} />
	{caption && <figcaption>{caption}</figcaption>}
</figure>
<style>
	figure {
		margin: 2em 0;
		padding: 0;
		background-color: #0d0a1a;
		line-height: 0;
	}
	figure > img {
		display: block;
		max-width: 100%;
		height: auto;
		border-radius: 0 !important;
		margin: 0 auto;
	}
	figure > figcaption {
		display: block;
		margin-top: 0.75em;
		font-size: 0.8em;
		color: var(--color-text-muted);
		font-style: italic;
		line-height: 1.5;
		text-align: center;
	}
</style>
