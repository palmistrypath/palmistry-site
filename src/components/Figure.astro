---
interface Props {
	src: string;
	alt: string;
	caption?: string;
}

const { src, alt, caption } = Astro.props;
---

<figure>
	<img src={src} alt={alt} />
	{caption && <figcaption>{caption}</figcaption>}
</figure>
<style>
	figure {
		margin: 2em 0;
		text-align: center;
	}
	img {
		border-radius: 8px;
		box-shadow: var(--box-shadow);
		max-width: 100%;
		height: auto;
	}
	figcaption {
		margin-top: 0.75em;
		font-size: 0.8em;
		color: var(--color-text-muted);
		font-style: italic;
	}
</style>
