---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`The Palmistry Starter Guide — ${SITE_TITLE}`}
			description="A printable quick-reference guide to the major lines, mounts, and hand shapes. Join the early access list."
		/>
		<style>
			/* ── Hero ─────────────────────────────────────────────────── */
			.guide-hero {
				text-align: center;
				padding: 4.5em 1em 2.5em;
				background: radial-gradient(
					ellipse 65% 50% at 50% 40%,
					rgba(201, 169, 110, 0.07) 0%,
					transparent 70%
				);
			}
			.guide-eyebrow {
				font-family: var(--font-cinzel), serif;
				font-size: 0.58em;
				letter-spacing: 0.22em;
				text-transform: uppercase;
				color: var(--color-text-muted);
				margin: 0 0 1.1em;
				opacity: 0.7;
			}
			.guide-hero h1 {
				font-size: clamp(1.6rem, 6vw, 3em);
				letter-spacing: 0.08em;
				color: var(--accent);
				text-shadow:
					0 0 80px rgba(201, 169, 110, 0.18),
					0 2px 8px rgba(0, 0, 0, 0.7);
				margin: 0 0 0.5em;
			}
			.guide-hero .subline {
				font-size: 0.9em;
				color: var(--color-text-muted);
				max-width: 480px;
				margin: 0 auto;
				line-height: 1.75;
			}

			/* ── Divider ──────────────────────────────────────────────── */
			.divider {
				text-align: center;
				color: var(--accent);
				letter-spacing: 0.5em;
				font-size: 0.6em;
				opacity: 0.45;
				padding: 2.5em 0 0;
				margin-bottom: 2.5em;
			}

			/* ── Shared section wrapper ───────────────────────────────── */
			.guide-section {
				width: 640px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 0 1em;
			}

			/* ── What's inside ────────────────────────────────────────── */
			.section-heading {
				font-family: var(--font-cinzel), serif;
				font-size: 0.62em;
				letter-spacing: 0.2em;
				text-transform: uppercase;
				color: var(--color-text-muted);
				opacity: 0.6;
				text-align: center;
				margin: 0 0 1.75em;
			}
			.contents-grid {
				list-style: none;
				margin: 0 0 3.5em;
				padding: 0;
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1.25em 2em;
			}
			.contents-grid li {
				border-top: 1px solid rgba(201, 169, 110, 0.15);
				padding-top: 0.9em;
			}
			.item-title {
				display: block;
				font-family: var(--font-cinzel), serif;
				font-size: 0.78em;
				letter-spacing: 0.06em;
				color: var(--color-heading);
				margin-bottom: 0.35em;
				line-height: 1.3;
			}
			.item-desc {
				display: block;
				font-size: 0.76em;
				color: var(--color-text-muted);
				line-height: 1.65;
				opacity: 0.8;
			}

			/* ── Signup block ─────────────────────────────────────────── */
			.signup-block {
				text-align: center;
				padding: 0 0 5em;
			}
			.signup-note {
				font-size: 0.87em;
				color: var(--color-text-muted);
				max-width: 440px;
				margin: 0 auto 1.5em;
				line-height: 1.75;
			}
			.signup-form {
				display: flex;
				gap: 0.7em;
				max-width: 460px;
				margin: 0 auto 0.85em;
			}
			.signup-form input[type='email'] {
				flex: 1;
				background: rgba(255, 255, 255, 0.04);
				border: 1px solid rgba(201, 169, 110, 0.28);
				border-radius: 4px;
				color: var(--color-text);
				font-family: var(--font-lora), serif;
				font-size: 0.82em;
				padding: 0.75em 1em;
				outline: none;
				transition:
					border-color 0.2s ease,
					box-shadow 0.2s ease;
				min-width: 0; /* prevent flex overflow */
			}
			.signup-form input[type='email']::placeholder {
				color: var(--color-text-muted);
				opacity: 0.55;
			}
			.signup-form input[type='email']:focus {
				border-color: rgba(201, 169, 110, 0.55);
				box-shadow: 0 0 0 3px rgba(201, 169, 110, 0.07);
			}
			.signup-form button {
				background: var(--accent);
				border: none;
				border-radius: 4px;
				color: var(--color-bg);
				font-family: var(--font-cinzel), serif;
				font-size: 0.68em;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				padding: 0.8em 1.5em;
				cursor: pointer;
				white-space: nowrap;
				transition:
					background 0.2s ease,
					box-shadow 0.2s ease;
			}
			.signup-form button:hover {
				background: var(--accent-light);
				box-shadow: 0 2px 14px rgba(201, 169, 110, 0.2);
			}
			.signup-form button:active {
				background: var(--accent);
				box-shadow: none;
			}
			.signup-caveat {
				font-size: 0.72em;
				color: var(--color-text-muted);
				opacity: 0.55;
				margin: 0;
				letter-spacing: 0.02em;
			}
			/* Confirmation state (shown by JS after submit) */
			.signup-confirm {
				display: none;
				font-size: 0.87em;
				color: var(--color-text-muted);
				max-width: 440px;
				margin: 0 auto;
				line-height: 1.75;
			}

			/* ── Mobile ───────────────────────────────────────────────── */
			@media (max-width: 600px) {
				.guide-hero {
					padding: 3em 1em 2em;
				}
				.divider {
					padding-top: 1.75em;
					margin-bottom: 1.75em;
				}
				.contents-grid {
					grid-template-columns: 1fr;
					gap: 1.1em;
					margin-bottom: 2.5em;
				}
				.signup-form {
					flex-direction: column;
				}
				.signup-form button {
					width: 100%;
					padding: 0.85em 1em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="guide-hero">
				<p class="guide-eyebrow">Free Download</p>
				<h1>The Palmistry Starter Guide</h1>
				<p class="subline">
					A printable quick-reference guide to the major lines, mounts, and hand shapes.
				</p>
			</section>

			<div class="divider" aria-hidden="true">✦ · ✦ · ✦</div>

			<div class="guide-section">
				<h2 class="section-heading">What's inside</h2>
				<ul class="contents-grid">
					<li>
						<span class="item-title">Major Lines Map</span>
						<span class="item-desc"
							>A reference diagram of the four major lines with their traditional names and
							locations.</span
						>
					</li>
					<li>
						<span class="item-title">Mount Meanings Overview</span>
						<span class="item-desc"
							>An overview of all eight mounts, their associated qualities, and how to assess
							prominence.</span
						>
					</li>
					<li>
						<span class="item-title">Hand Shape Guide</span>
						<span class="item-desc"
							>A visual key to the elemental hand types — Earth, Air, Fire, and Water — and their
							characteristic forms.</span
						>
					</li>
					<li>
						<span class="item-title">Printable Study Sheet</span>
						<span class="item-desc"
							>A simple observation page for recording your own hand's features as you work through
							the lessons.</span
						>
					</li>
				</ul>
			</div>

			<div class="guide-section signup-block">
				<p class="signup-note" id="signup-note">
					The guide is currently in preparation. Leave your email below and you'll be the first to
					receive it when it's ready.
				</p>
				<form
					class="signup-form"
					id="signup-form"
					action=""
					aria-label="Early access sign-up"
					novalidate
				>
					<label for="guide-email" class="sr-only">Email address</label>
					<input
						type="email"
						id="guide-email"
						name="email"
						placeholder="Your email address"
						autocomplete="email"
						required
					/>
					<button type="submit">Join the Early Access List</button>
				</form>
				<p class="signup-confirm" id="signup-confirm">
					You're on the list. We'll send a single email when the guide is ready — nothing else.
				</p>
				<p class="signup-caveat" id="signup-caveat">
					No spam. One email when the guide is ready.
				</p>
			</div>
		</main>
		<Footer />

		<script>
			const form = document.getElementById('signup-form') as HTMLFormElement | null;
			const note = document.getElementById('signup-note');
			const confirm = document.getElementById('signup-confirm');
			const caveat = document.getElementById('signup-caveat');

			form?.addEventListener('submit', (e) => {
				e.preventDefault();
				if (form) form.style.display = 'none';
				if (note) note.style.display = 'none';
				if (caveat) caveat.style.display = 'none';
				if (confirm) confirm.style.display = 'block';
			});
		</script>
	</body>
</html>
