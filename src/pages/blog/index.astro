---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featuredIds = [
	'beginner/what-palmistry-is',
	'beginner/how-to-read-a-palm',
	'beginner/major-lines-overview',
];
const featuredPosts = featuredIds
	.map((id) => posts.find((p) => p.id === id))
	.filter((p) => p !== undefined);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: calc(100% - 3rem);
				max-width: 1400px;
			}

			/* ---- Start Here section ---- */
			.start-here {
				margin-bottom: 3rem;
			}
			.start-here > .intro {
				margin-top: 0.5rem;
				margin-bottom: 1.5rem;
				color: var(--color-text-muted);
				font-size: 0.9em;
			}
			.featured-list {
				display: flex;
				flex-wrap: wrap;
				gap: 1.5rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			/* Override the general ul li:first-child rules for featured cards */
			.featured-list li,
			.featured-list li:first-child {
				width: calc(33.33% - 1rem);
				margin-bottom: 0;
				text-align: left;
			}
			.featured-list li:first-child .title {
				font-size: 1.563em;
			}
			.featured-list li a {
				display: block;
				height: 100%;
				padding: 1.25rem;
				border: 1px solid rgba(201, 169, 110, 0.3);
				border-radius: 12px;
				background: rgba(255, 255, 255, 0.03);
				text-decoration: none;
				transition: 0.2s ease;
				box-sizing: border-box;
			}
			.featured-list li a:hover {
				border-color: var(--accent);
				background: rgba(201, 169, 110, 0.06);
				box-shadow: var(--box-shadow);
			}
			.featured-list .title {
				margin: 0 0 0.5rem;
				color: var(--color-heading);
				line-height: 1.3;
			}
			.featured-list .description {
				margin: 0;
				color: var(--color-text-muted);
				font-size: 0.8em;
				line-height: 1.5;
			}

			/* ---- Section headings ---- */
			.section-label {
				margin: 0 0 1.5rem;
			}

			/* ---- All Articles list (existing patterns) ---- */
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0;
				color: var(--color-text);
				line-height: 1;
			}
			.description {
				margin: 0.25rem 0 0;
				color: var(--color-text-muted);
				font-size: 0.8em;
				line-height: 1.5;
			}
			.date {
				margin: 0;
				color: var(--color-text-muted);
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: var(--accent);
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}

			@media (max-width: 720px) {
				.featured-list li,
				.featured-list li:first-child {
					width: 100%;
				}
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}

			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="start-here">
				<h2 class="section-label">New to Palmistry Path? Start here</h2>
				<p class="intro">These three articles give you the foundation for everything else on this site.</p>
				<ul class="featured-list">
					{
						featuredPosts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<h4 class="title">{post.data.title}</h4>
									<p class="description">{post.data.description}</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
			<section>
				<h2 class="section-label">All Articles</h2>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<Image width={720} height={360} src={post.data.heroImage} alt="" />
									)}
									<h4 class="title">{post.data.title}</h4>
									<p class="description">{post.data.description.length > 120 ? post.data.description.slice(0, 120) + '…' : post.data.description}</p>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
