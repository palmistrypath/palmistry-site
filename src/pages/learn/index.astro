---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { MODULES, SITE_TITLE } from '../../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Learn Palmistry — ${SITE_TITLE}`}
			description="A structured learning path through palmistry — from foundational concepts to advanced interpretation."
		/>
		<style>
			main {
				width: calc(100% - 3rem);
				max-width: 1000px;
			}
			.page-header {
				text-align: center;
				padding: 3.5em 1em 2.5em;
				background: radial-gradient(
					ellipse 70% 55% at 50% 42%,
					rgba(201, 169, 110, 0.06) 0%,
					transparent 70%
				);
			}
			.page-header h1 {
				font-size: clamp(1.5rem, 6vw, 3em);
				letter-spacing: 0.1em;
				color: var(--accent);
				text-shadow:
					0 0 80px rgba(201, 169, 110, 0.18),
					0 2px 8px rgba(0, 0, 0, 0.7);
				margin-bottom: 0.4em;
			}
			.page-header .intro {
				font-family: var(--font-cinzel), serif;
				font-size: 0.68em;
				letter-spacing: 0.2em;
				text-transform: uppercase;
				color: #a09abf;
				margin: 0;
			}
			.divider {
				text-align: center;
				color: var(--accent);
				letter-spacing: 0.5em;
				font-size: 0.6em;
				opacity: 0.5;
				padding: 2em 0;
			}
			.module-grid {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 1.5rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.module-grid li a {
				display: block;
				height: 100%;
				padding: 1.5rem;
				border: 1px solid rgba(201, 169, 110, 0.3);
				border-radius: 12px;
				background: rgba(255, 255, 255, 0.03);
				text-decoration: none;
				transition: 0.2s ease;
				box-sizing: border-box;
			}
			.module-grid li a:hover {
				border-color: var(--accent);
				background: rgba(201, 169, 110, 0.06);
				box-shadow: var(--box-shadow);
			}
			.module-difficulty {
				display: block;
				font-family: var(--font-cinzel), serif;
				font-size: 0.68em;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: var(--accent);
				margin-bottom: 0.6rem;
			}
			.module-title {
				margin: 0 0 0.5rem;
				font-family: var(--font-cinzel), serif;
				font-size: 1.15em;
				color: var(--color-heading);
				line-height: 1.3;
			}
			.module-description {
				margin: 0;
				color: var(--color-text-muted);
				font-size: 0.82em;
				line-height: 1.6;
			}
			@media (max-width: 640px) {
				.page-header {
					padding: 2.5em 1em 2em;
				}
				.module-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="page-header">
				<h1>Learn Palmistry</h1>
				<p class="intro">A structured path from first principles to nuanced interpretation.</p>
			</section>
			<div class="divider" aria-hidden="true">✦ · ✦ · ✦</div>
			<ul class="module-grid">
				{
					MODULES.map((mod, i) => (
						<li>
							<a href={`/learn/${mod.slug}`}>
								<span class="module-difficulty">{mod.difficulty}</span>
								<p class="module-title">
									{i + 1}. {mod.title}
								</p>
								<p class="module-description">{mod.description}</p>
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
